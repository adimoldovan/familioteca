<header class="catalog-header">
  <h1 class="t-headline"><%= t(".title") %></h1>

  <%= form_with url: root_path, method: :get, class: "catalog-search" do |f| %>
    <%= f.label :q, t(".search.label"), class: "catalog-search__label" %>
    <%= f.search_field :q, value: @query,
          placeholder: t(".search.placeholder"),
          class: "catalog-search__input" %>
    <%= f.submit t(".search.submit"), class: "btn btn-secondary" %>
  <% end %>
</header>

<% if @books.empty? %>
  <div class="empty-state">
    <% if @query.present? %>
      <p class="empty-state__body"><%= t(".search.no_results", query: @query) %></p>
    <% else %>
      <p class="empty-state__body"><%= t(".empty") %></p>
    <% end %>
  </div>
<% else %>
  <ul class="book-grid">
    <% @books.each do |book| %>
      <li class="book-grid__item"><%= render "card", book: book %></li>
    <% end %>
  </ul>
<% end %>
