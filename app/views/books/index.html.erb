<div class="catalog-toolbar">
  <div class="sort">
    <% %w[date title author].each do |s| %>
      <%= link_to t(".sort.#{s}"),
            url_for(sort: s, dir: s == @sort ? @dir : nil, q: @query.presence, filter: @filter == "all" ? nil : @filter),
            class: class_names("sort-btn", "is-active" => @sort == s),
            data: { turbo_action: "replace" } %>
    <% end %>

    <span class="sort-divider" aria-hidden="true"></span>

    <% flipped = @dir == "asc" ? "desc" : "asc" %>
    <%= link_to url_for(sort: @sort, dir: flipped, q: @query.presence, filter: @filter == "all" ? nil : @filter),
          class: "sort-dir",
          aria: { label: t(".sort.dir_#{flipped}") },
          data: { turbo_action: "replace" } do %>
      <% if @dir == "asc" %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14M5 12l7-7 7 7"/></svg>
      <% else %>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 19V5M5 12l7 7 7-7"/></svg>
      <% end %>
    <% end %>
  </div>
</div>

<div class="catalog-layout">
  <aside class="catalog-sidebar" aria-label="<%= t(".filters.label") %>">
    <div class="catalog-sidebar__search" data-controller="live-search">
      <svg class="catalog-sidebar__search-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <%= search_field_tag :q, @query,
            placeholder: t(".search.placeholder"),
            class: "catalog-sidebar__search-input",
            id: "search-input",
            autocomplete: "off",
            data: { live_search_target: "input", action: "input->live-search#search" } %>
      <button type="button" class="catalog-sidebar__search-clear" id="search-clear" data-action="live-search#clear" aria-label="<%= t(".search.clear") %>" <%= "hidden" if @query.blank? %>>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"><path d="M6 6l12 12M18 6l-12 12"/></svg>
      </button>
    </div>

    <div class="catalog-sidebar__section">
      <p class="catalog-sidebar__label"><%= t(".filters.reading_status") %></p>
      <ul class="catalog-sidebar__filters" role="group">
        <% %w[all unread read].each do |f| %>
          <li>
            <%= link_to url_for(filter: f, q: @query.presence, sort: @sort, dir: @dir),
                  class: class_names("catalog-sidebar__filter-item", "is-active" => @filter == f),
                  data: { turbo_action: "replace" } do %>
              <span><%= t(".filters.#{f}") %></span>
              <span class="catalog-sidebar__filter-count"><%= @counts[f.to_sym] %></span>
            <% end %>
          </li>
        <% end %>
      </ul>
    </div>
  </aside>

  <% if @books.empty? %>
    <div class="empty-state">
      <% if @query.present? %>
        <p class="empty-state__body"><%= t(".search.no_results", query: @query) %></p>
      <% else %>
        <p class="empty-state__body"><%= t(".empty") %></p>
      <% end %>
    </div>
  <% else %>
    <ul class="book-grid" id="book-grid">
      <% @books.each do |book| %>
        <li class="book-grid__item"><%= render "card", book: book %></li>
      <% end %>
    </ul>
  <% end %>
</div>
