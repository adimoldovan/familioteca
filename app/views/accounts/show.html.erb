<nav class="crumbs" aria-label="<%= t("navigation.breadcrumb") %>">
  <%= link_to t("navigation.catalog"), root_path %>
  <span class="crumbs__sep" aria-hidden="true">/</span>
  <span class="crumbs__current"><%= t("account.show.title") %></span>
</nav>

<%= form_with model: @member, url: account_path, method: :patch, id: "account-form", class: "content-form" do |f| %>
  <% if @member.errors.any? %>
    <div class="error-summary">
      <h2 class="error-summary__title"><%= t("account.show.errors_title") %></h2>
      <ul class="error-summary__list">
        <% @member.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-field">
    <div class="form-field__header">
      <%= f.label :name, t("account.show.name"), class: "form-field__label" %>
    </div>
    <%= f.text_field :name, class: "form-field__input", required: true, id: "account-name" %>
  </div>

  <div class="form-field">
    <div class="form-field__header">
      <label for="account-email" class="form-field__label"><%= t("account.show.email") %></label>
    </div>
    <input type="email" value="<%= @member.email %>" class="form-field__input" id="account-email" disabled>
  </div>

  <div class="form-field">
    <div class="form-field__header">
      <%= f.label :reading_speed_wpm, t("account.show.reading_speed_wpm"), class: "form-field__label" %>
    </div>
    <%= f.number_field :reading_speed_wpm, class: "form-field__input", id: "account-reading-speed",
          min: Member::READING_SPEED_RANGE.min, max: Member::READING_SPEED_RANGE.max, step: 1 %>
    <p class="form-field__hint"><%= t("account.show.reading_speed_hint", wpm: Member::DEFAULT_READING_SPEED_WPM) %></p>
  </div>

  <div class="form-field">
    <div class="form-field__header">
      <%= f.label :kindle_email, t("account.show.kindle_email"), class: "form-field__label" %>
    </div>
    <%= f.email_field :kindle_email, class: "form-field__input", id: "account-kindle-email" %>
  </div>

  <div class="form-field">
    <label class="form-check" for="account-kindle-sender-approved">
      <%= f.check_box :kindle_sender_approved, class: "form-check__input", id: "account-kindle-sender-approved" %>
      <span class="form-check__label"><%= t("account.show.kindle_sender_approved", sender_email: @sender_email) %></span>
    </label>

    <details class="kindle-setup" id="kindle-setup-instructions">
      <summary class="kindle-setup__summary"><%= t("account.show.kindle_setup_link") %></summary>

      <div class="kindle-setup__body">
        <section class="kindle-setup__section">
          <h3 class="kindle-setup__heading"><%= t("account.show.kindle_setup.step1_title") %></h3>
          <p><%= t("account.show.kindle_setup.step1_body") %></p>
        </section>

        <section class="kindle-setup__section">
          <h3 class="kindle-setup__heading"><%= t("account.show.kindle_setup.step2_title") %></h3>
          <ol class="kindle-setup__steps">
            <li><%= t("account.show.kindle_setup.step2_1") %></li>
            <li><%= t("account.show.kindle_setup.step2_2_html") %></li>
            <li><%= t("account.show.kindle_setup.step2_3") %></li>
            <li><%= t("account.show.kindle_setup.step2_4", sender_email: @sender_email) %></li>
          </ol>
        </section>

        <section class="kindle-setup__section">
          <h3 class="kindle-setup__heading"><%= t("account.show.kindle_setup.step3_title") %></h3>
          <ol class="kindle-setup__steps">
            <li><%= t("account.show.kindle_setup.step3_1") %></li>
            <li><%= t("account.show.kindle_setup.step3_2") %></li>
          </ol>
        </section>
      </div>
    </details>
  </div>

  <div class="content-form__actions">
    <%= f.submit t("account.show.submit"), class: "btn btn-primary", id: "account-submit" %>
  </div>
<% end %>
