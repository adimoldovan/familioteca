<div class="content-form__header">
  <h1 id="book-edit-heading" class="t-headline"><%= t(".title") %></h1>
  <% if @prev_book_id || @next_book_id %>
    <nav class="book-edit-nav" aria-label="<%= t(".nav_label") %>">
      <% if @prev_book_id %>
        <%= link_to t(".previous"), edit_admin_book_path(@prev_book_id, filter: @filter), class: "btn btn-secondary" %>
      <% end %>
      <% if @next_book_id %>
        <%= link_to t(".next"), edit_admin_book_path(@next_book_id, filter: @filter), class: "btn btn-secondary" %>
      <% end %>
    </nav>
  <% end %>
</div>

<%= form_with model: @book, url: admin_book_path(@book, filter: @filter), method: :patch, id: "book-edit-form", class: "content-form" do |f| %>
  <% if @book.errors.any? %>
    <div class="error-summary">
      <h2 class="error-summary__title"><%= t(".errors_title") %></h2>
      <ul class="error-summary__list">
        <% @book.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="form-field">
    <div class="form-field__header">
      <%= f.label :title, t("admin.books.fields.title"), class: "form-field__label" %>
    </div>
    <%= f.text_field :title, class: "form-field__input", required: true %>
  </div>

  <% %i[author language publisher isbn].each do |field| %>
    <div class="form-field">
      <div class="form-field__header">
        <%= f.label field, t("admin.books.fields.#{field}"), class: "form-field__label" %>
      </div>
      <%= f.text_field field, class: "form-field__input" %>
    </div>
  <% end %>

  <div class="form-field">
    <div class="form-field__header">
      <%= f.label :goodreads_url, t("admin.books.fields.goodreads_url"), class: "form-field__label" %>
    </div>
    <%= f.url_field :goodreads_url, class: "form-field__input", placeholder: "https://www.goodreads.com/book/show/..." %>
  </div>

  <div class="form-field">
    <div class="form-field__header">
      <%= f.label :published_year, t("admin.books.fields.published_year"), class: "form-field__label" %>
    </div>
    <%= f.number_field :published_year, class: "form-field__input" %>
  </div>

  <fieldset class="form-field form-fieldset">
    <legend class="form-field__label form-fieldset__legend"><%= t("admin.books.fields.categories") %></legend>
    <%# Prefer submitted values so a validation-failure re-render keeps the user's selection,
        including when all boxes were cleared (params[:book] present but category_keys absent). %>
    <% selected = params.key?(:book) ? Array(params.dig(:book, :category_keys)) : @book.category_keys %>
    <% Book::CATEGORIES.each do |category| %>
      <label class="form-check form-fieldset__option">
        <%= check_box_tag "book[category_keys][]", category, selected.include?(category),
              id: "book_category_keys_#{category}", class: "form-check__input" %>
        <span class="form-check__label"><%= t("books.categories.#{category}") %></span>
      </label>
    <% end %>
  </fieldset>

  <div class="form-field">
    <div class="form-field__header">
      <%= f.label :description, t("admin.books.fields.description"), class: "form-field__label" %>
    </div>
    <%= f.text_area :description, class: "form-field__input", rows: 6 %>
  </div>

  <%= hidden_field_tag :next_book_id, @next_book_id if @next_book_id %>
<% end %>

<%# Actions live outside the form so the rescan button_to (its own <form>) does not
    nest inside the edit form. The submit buttons stay wired to it via form="book-edit-form". %>
<div class="content-form__actions content-form__actions--fill">
  <%= link_to t(".cancel"), admin_books_path(filter: @filter), class: "btn btn-secondary" %>
  <%= button_tag t(".submit"), type: "submit", form: "book-edit-form", class: "btn btn-primary" %>
  <% if @next_book_id %>
    <%= button_tag t(".save_and_next"), type: "submit", form: "book-edit-form", name: "save_action", value: "next", class: "btn btn-primary",
          title: t(".save_and_next_hotkey", label: t(".save_and_next")), aria: { keyshortcuts: "s" },
          data: { controller: "hotkey", hotkey_key_value: "s" } %>
  <% end %>
  <%= button_to t(".rescan_link"), rescan_admin_book_path(@book, filter: @filter),
        method: :post, class: "btn btn-secondary", form_class: "content-form__action-form" %>
</div>
