<%= render "admin/nav" %>
<%= render "admin/scan_button" %>

<h1 id="books-heading" class="t-headline"><%= t(".title") %></h1>

<nav class="admin-filter" aria-label="<%= t(".filter.label") %>">
  <%= render "filter_tab", label: t(".filter.all"), filter: nil, count: @counts[nil], active: @filter.nil?, alert: false %>
  <%= render "filter_tab", label: t(".filter.needs_metadata"), filter: "needs_metadata", count: @counts["needs_metadata"], active: @filter == "needs_metadata", alert: true %>
  <%= render "filter_tab", label: t(".filter.needs_goodreads"), filter: "needs_goodreads", count: @counts["needs_goodreads"], active: @filter == "needs_goodreads", alert: true %>
  <%= render "filter_tab", label: t(".filter.missing_category"), filter: "missing_category", count: @counts["missing_category"], active: @filter == "missing_category", alert: true %>
  <%= render "filter_tab", label: t(".filter.needs_rescan"), filter: "needs_rescan", count: @counts["needs_rescan"], active: @filter == "needs_rescan", alert: true %>
</nav>

<table class="data-table" aria-labelledby="books-heading">
  <thead>
    <tr>
      <th scope="col"><%= t(".table.title") %></th>
      <th scope="col"><%= t(".table.author") %></th>
      <th scope="col"><%= t(".table.format") %></th>
      <th scope="col"><%= t(".table.status") %></th>
      <th scope="col"><%= t(".table.actions") %></th>
    </tr>
  </thead>
  <tbody>
    <% @books.each do |book| %>
      <tr>
        <td><%= book.title %></td>
        <td><%= book.author || "—" %></td>
        <td><%= book.format.upcase %></td>
        <td>
          <% if book.missing? %>
            <%= t(".status.missing") %>
          <% elsif book.parse_error.present? %>
            <%= t(".status.needs_metadata") %>
          <% elsif book.needs_rescan? %>
            <%= t(".status.needs_rescan") %>
          <% else %>
            <%= t(".status.ok") %>
          <% end %>
        </td>
        <td>
          <%= link_to t(".edit_link"), edit_admin_book_path(book, filter: @filter), class: "link-accent" %>
          <%= button_to t(".delete_link"), admin_book_path(book),
                method: :delete,
                class: "link-danger",
                data: { turbo_confirm: t(".delete_confirm", title: book.title) },
                form: { class: "inline-form" } %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>
