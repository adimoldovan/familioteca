<%= render "admin/scan_button" %>

<h1 id="members-heading" class="t-headline"><%= t(".title") %></h1>

<table class="data-table" aria-labelledby="members-heading">
  <thead>
    <tr>
      <th scope="col"><%= t(".name") %></th>
      <th scope="col"><%= t(".email") %></th>
      <th scope="col"><%= t(".kindle_email") %></th>
      <th scope="col"><%= t(".role") %></th>
      <th scope="col"><%= t(".actions") %></th>
    </tr>
  </thead>
  <tbody>
    <% @members.each do |member| %>
      <tr>
        <td><%= member.name %></td>
        <td><%= member.email %></td>
        <td><%= member.kindle_email || "—" %></td>
        <td><%= member.admin? ? t(".admin") : t(".member") %></td>
        <td><%= button_to t(".reset_link"), reset_link_admin_member_path(member), class: "btn btn-sm" %></td>
      </tr>
    <% end %>
  </tbody>
</table>
