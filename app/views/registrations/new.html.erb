<main class="auth-minimal" aria-label="<%= t("registrations.new.title") %>">
  <div class="auth-minimal__nav">
    <%= link_to t("app.name"), root_path, class: "brand__name" %>
    <%= render "shared/theme_toggle" %>
  </div>

  <h1 class="t-headline"><%= t("registrations.new.title") %></h1>

  <% if @member.errors.any? %>
    <div class="error-summary">
      <h2 class="error-summary__title"><%= t("registrations.new.errors_title") %></h2>
      <ul class="error-summary__list">
        <% @member.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: @member, url: register_path(code: @invite_code.code), method: :post do |f| %>
    <div class="form-field">
      <div class="form-field__header">
        <%= f.label :name, t("registrations.new.name"), class: "form-field__label" %>
      </div>
      <%= f.text_field :name, id: "register-name", required: true, autofocus: true,
            class: "form-field__input" %>
    </div>

    <div class="form-field">
      <div class="form-field__header">
        <%= f.label :email, t("registrations.new.email"), class: "form-field__label" %>
      </div>
      <%= f.email_field :email, id: "register-email", required: true,
            class: "form-field__input" %>
    </div>

    <div class="form-field">
      <div class="form-field__header">
        <%= f.label :password, t("registrations.new.password"), class: "form-field__label" %>
      </div>
      <%= f.password_field :password, id: "register-password", required: true,
            class: "form-field__input" %>
    </div>

    <div class="form-field">
      <div class="form-field__header">
        <%= f.label :password_confirmation, t("registrations.new.password_confirmation"), class: "form-field__label" %>
      </div>
      <%= f.password_field :password_confirmation, id: "register-password-confirmation", required: true,
            class: "form-field__input" %>
    </div>

    <%= f.submit t("registrations.new.submit"), id: "register-submit", class: "btn btn-primary" %>
  <% end %>
</main>
