<main class="auth-minimal" aria-label="<%= t("sessions.new.title") %>">
  <div class="auth-minimal__nav">
    <%= link_to t("app.name"), root_path, class: "brand__name" %>
    <%= render "shared/theme_toggle" %>
  </div>

  <h1 class="t-headline"><%= t("sessions.new.title") %></h1>

  <% if flash[:error] %>
    <p id="sign-in-error" class="flash-error"><%= flash[:error] %></p>
  <% end %>

  <%= form_with url: session_path, method: :post do |f| %>
    <div class="form-field">
      <div class="form-field__header">
        <%= f.label :email, t("sessions.new.email"), for: "sign-in-email", class: "form-field__label" %>
      </div>
      <%= f.email_field :email, id: "sign-in-email", required: true, autofocus: true,
            class: "form-field__input" %>
    </div>

    <div class="form-field">
      <div class="form-field__header">
        <%= f.label :password, t("sessions.new.password"), for: "sign-in-password", class: "form-field__label" %>
      </div>
      <%= f.password_field :password, id: "sign-in-password", required: true,
            class: "form-field__input" %>
    </div>

    <%= f.submit t("sessions.new.submit"), id: "sign-in-submit", class: "btn btn-primary" %>
  <% end %>
</main>
