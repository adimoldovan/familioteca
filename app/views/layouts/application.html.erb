<!DOCTYPE html>
<html lang="ro">
  <head>
    <title><%= content_for(:title) || t("app.name") %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("app.name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <script nonce="<%= content_security_policy_nonce %>">
      (function () {
        try {
          var theme = localStorage.getItem("theme");
          if (theme === "dark") {
            document.documentElement.classList.add("dark");
          } else if (theme === null && window.matchMedia("(prefers-color-scheme: dark)").matches) {
            document.documentElement.classList.add("dark");
          }
        } catch (e) {}
      })();
    </script>
  </head>

  <body>
    <%= render "shared/flash" %>

    <% if signed_in? %>
      <header class="site-header">
        <div class="site-header__bar">
          <%= link_to t("app.name"), root_path, id: "site-header-brand", class: "site-header__brand" %>
          <nav class="site-header__nav" aria-label="<%= t("navigation.primary") %>">
            <%= link_to t("navigation.catalog"), root_path, id: "nav-catalog" %>
            <%= link_to t("navigation.account"), account_path, id: "nav-account" %>
            <% if current_member.admin? %>
              <%= link_to t("navigation.admin"), admin_books_path, id: "nav-admin" %>
            <% end %>
          </nav>
          <div class="site-header__account">
            <span class="site-header__current-member" id="current-member-name"><%= current_member.name %></span>
            <%= button_to t("sessions.destroy.link"), session_path, method: :delete,
                  form: { id: "sign-out-form" },
                  class: "site-header__sign-out",
                  id: "nav-sign-out" %>
            <%= render "shared/theme_toggle" %>
          </div>
        </div>
      </header>

      <main class="site-main">
        <%= yield %>
      </main>
    <% else %>
      <%= yield %>
    <% end %>
  </body>
</html>
