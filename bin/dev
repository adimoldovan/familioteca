#!/usr/bin/env bash
set -euo pipefail

PORT="${PORT:-3005}"
BIND="${BIND:-127.0.0.1}"
DEV_URL="http://localhost:$PORT/"
ADMIN_LOGIN="${FAMILIOTECA_ADMIN_EMAIL:-admin@familioteca.local} / ${FAMILIOTECA_ADMIN_PASSWORD:-changeme123}"
DEMO_LOGIN="demo@familioteca.local / password"

if [ -t 1 ]; then
  c_bar='\033[2m▎\033[0m'
  c_label='\033[37m'
  c_url='\033[96m'
  c_reset='\033[0m'
else
  c_bar='▎'
  c_label=''
  c_url=''
  c_reset=''
fi

printf "\n"
printf " %b %bURL%b     %b%s%b\n" "$c_bar" "$c_label" "$c_reset" "$c_url" "$DEV_URL" "$c_reset"
printf " %b %bAdmin%b   %s\n" "$c_bar" "$c_label" "$c_reset" "$ADMIN_LOGIN"
printf " %b %bDemo%b    %s\n" "$c_bar" "$c_label" "$c_reset" "$DEMO_LOGIN"
printf "\n"

bin/rails tailwindcss:watch &
TAILWIND_PID=$!
cleanup() {
  trap - EXIT INT TERM
  kill "$TAILWIND_PID" 2>/dev/null || true
  wait "$TAILWIND_PID" 2>/dev/null || true
}
trap 'cleanup; exit 130' INT
trap 'cleanup; exit 143' TERM
trap cleanup EXIT

bin/rails server -b "$BIND" -p "$PORT"
