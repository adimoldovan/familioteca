{
  "name": "familioteca-e2e",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "test:e2e": "E2E_PORT=$(node test/e2e/find-port.cjs) playwright test",
    "test:js": "vitest run",
    "test:js:watch": "vitest",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "typecheck": "tsc --noEmit",
    "db:reset": "RAILS_ENV=e2e bin/rails db:drop db:create db:migrate"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "E2E tests for Familioteca app",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@hotwired/stimulus": "^3.2.2",
    "@playwright/test": "^1.60.0",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.0",
    "eslint-plugin-playwright": "^2.10.4",
    "globals": "^17.6.0",
    "happy-dom": "^20.9.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  }
}
